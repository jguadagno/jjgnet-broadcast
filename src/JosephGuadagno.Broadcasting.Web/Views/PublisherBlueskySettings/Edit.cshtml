@model JosephGuadagno.Broadcasting.Web.Models.BlueskyPublisherSettingsViewModel

@{
    ViewData["Title"] = "Edit Bluesky Settings";
}

<div class="d-flex flex-column flex-lg-row justify-content-between align-items-lg-center gap-3 mb-4">
    <div>
        <h1 class="mb-1">
            <i class="bi bi-bluesky me-2"></i>Bluesky Settings
        </h1>
        <p class="text-muted mb-0">Configure the settings for publishing to Bluesky.</p>
    </div>
    <div>
        <a asp-action="Index" class="btn btn-outline-secondary">
            <i class="bi bi-arrow-left me-1"></i>Back
        </a>
    </div>
</div>

<div class="card shadow-sm">
    <div class="card-body">
        <form asp-action="Save" method="post" novalidate>
            <div asp-validation-summary="ModelOnly" class="text-danger mb-3"></div>
            <input asp-for="Id" type="hidden" />
            <input asp-for="HasAppPassword" type="hidden" />

            <div class="form-check form-switch mb-3">
                <input asp-for="IsEnabled" class="form-check-input" />
                <label asp-for="IsEnabled" class="form-check-label">Enable Bluesky publishing</label>
            </div>

            <div class="mb-3">
                <label asp-for="UserName" class="form-label"></label>
                <input asp-for="UserName" class="form-control" autocomplete="username" />
                <span asp-validation-for="UserName" class="text-danger"></span>
            </div>

            <div class="rounded border p-3 bg-body-tertiary">
                <div class="d-flex justify-content-between align-items-center mb-2">
                    <h2 class="h6 mb-0">Credentials</h2>
                    @if (Model.HasAppPassword)
                    {
                        <span class="badge text-bg-secondary">Stored</span>
                    }
                </div>
                @if (Model.HasAppPassword)
                {
                    <p class="text-muted small mb-3">
                        App password: <span class="fw-semibold">@Model.MaskedValue</span>
                    </p>
                }
                <div class="form-check form-switch mb-3">
                    <input asp-for="ChangeCredentials" class="form-check-input" />
                    <label asp-for="ChangeCredentials" class="form-check-label">Change credentials</label>
                </div>
                <div class="mb-0">
                    <label asp-for="AppPassword" class="form-label"></label>
                    <input asp-for="AppPassword" class="form-control" autocomplete="new-password"
                           placeholder="@(Model.HasAppPassword ? "Leave blank to keep the stored app password" : "Enter app password")" />
                    <div class="form-text">Stored secrets are never shown again after save.</div>
                    <span asp-validation-for="AppPassword" class="text-danger"></span>
                </div>
            </div>

            <div class="mt-3 d-flex gap-2">
                <button type="submit" class="btn btn-primary">
                    <i class="bi bi-floppy me-2"></i>Save
                </button>
                <a asp-action="Index" class="btn btn-outline-secondary">Cancel</a>
            </div>
        </form>
    </div>
</div>

@section Scripts {
    @{ await Html.RenderPartialAsync("_ValidationScriptsPartial"); }
}
