@model JosephGuadagno.Broadcasting.Web.Models.BlueskyPublisherSettingsViewModel

@{
    ViewData["Title"] = "Bluesky Settings";
}

<div class="d-flex flex-column flex-lg-row justify-content-between align-items-lg-center gap-3 mb-4">
    <div>
        <h1 class="mb-1">
            <i class="bi bi-cloud me-2"></i>Bluesky Settings
        </h1>
        <p class="text-muted mb-0">Your Bluesky publisher configuration.</p>
    </div>
    <div>
        <a asp-controller="Publishers" asp-action="Index" class="btn btn-outline-secondary">
            <i class="bi bi-arrow-left me-1"></i>All Publishers
        </a>
    </div>
</div>

<div class="card shadow-sm">
    <div class="card-header d-flex justify-content-between align-items-center">
        <div>
            <i class="bi bi-cloud me-2"></i><strong>Bluesky</strong>
        </div>
        <span class="badge @(Model.IsEnabled ? "text-bg-success" : "text-bg-secondary")">
            @(Model.IsEnabled ? "Enabled" : "Disabled")
        </span>
    </div>
    <div class="card-body">
        @if (Model.Id == 0)
        {
            <p class="text-muted">Bluesky has not been configured yet.</p>
        }
        else
        {
            <dl class="row mb-0">
                <dt class="col-sm-4">Handle</dt>
                <dd class="col-sm-8">@(Model.UserName ?? "—")</dd>
                <dt class="col-sm-4">App password</dt>
                <dd class="col-sm-8">@(Model.HasAppPassword ? Model.MaskedValue : "Not set")</dd>
            </dl>
        }
    </div>
    <div class="card-footer text-end">
        <a asp-action="Edit" class="btn btn-primary btn-sm">
            <i class="bi bi-pencil me-1"></i>@(Model.Id == 0 ? "Configure" : "Edit Settings")
        </a>
    </div>
</div>
