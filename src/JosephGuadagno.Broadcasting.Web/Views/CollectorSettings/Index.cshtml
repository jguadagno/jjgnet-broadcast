@model JosephGuadagno.Broadcasting.Web.Models.CollectorSettingsPageViewModel

@{
    ViewData["Title"] = Model.IsManagedBySiteAdmin
        ? $"Collector Settings - {Model.TargetUserDisplayName ?? Model.TargetUserEntraOid}"
        : "Collector Settings";
}

<div class="d-flex flex-column flex-lg-row justify-content-between align-items-lg-center gap-3 mb-4">
    <div>
        <h1 class="mb-1">
            <i class="bi bi-rss-fill me-2"></i>Collector Settings
        </h1>
        <p class="text-muted mb-0">
            Configure the RSS/Atom/JSON feeds, YouTube channels, and speaking engagements to collect content from.
        </p>
    </div>
</div>

@if (Model.IsManagedBySiteAdmin)
{
    <div class="alert alert-info" role="alert">
        <i class="bi bi-shield-lock me-2"></i>
        You are managing collector settings for <strong>@(Model.TargetUserDisplayName ?? Model.TargetUserEntraOid)</strong>.
    </div>
}

<!-- RSS / Atom / JSON Feed Sources Section -->
<div class="card mb-4">
    <div class="card-header d-flex justify-content-between align-items-center">
        <h3 class="mb-0">
            <i class="bi bi-rss me-2"></i>RSS / Atom / JSON Feed Sources
        </h3>
        <a asp-controller="CollectorFeedSources" asp-action="Add" class="btn btn-primary">
            <i class="bi bi-plus-circle me-1"></i>Add Feed Source
        </a>
    </div>
    <div class="card-body">
        @if (Model.FeedSources.Count == 0)
        {
            <p class="text-muted mb-0">No feed sources configured. Click "Add Feed Source" to get started.</p>
        }
        else
        {
            <div class="table-responsive">
                <table class="table table-hover">
                    <thead class="table-dark">
                        <tr>
                            <th>Display Name</th>
                            <th>Feed URL</th>
                            <th>Status</th>
                            <th>Actions</th>
                        </tr>
                    </thead>
                    <tbody>
                        @foreach (var feedSource in Model.FeedSources)
                        {
                            <tr>
                                <td>@feedSource.DisplayName</td>
                                <td><a href="@feedSource.FeedUrl" target="_blank" rel="noopener noreferrer">@feedSource.FeedUrl</a></td>
                                <td>
                                    <span class="badge @(feedSource.IsActive ? "text-bg-success" : "text-bg-secondary")">
                                        @(feedSource.IsActive ? "Active" : "Inactive")
                                    </span>
                                </td>
                                <td>
                                    <a asp-controller="CollectorFeedSources" asp-action="Edit" asp-route-id="@feedSource.Id" class="btn btn-sm btn-outline-primary">
                                        <i class="bi bi-pencil"></i> Edit
                                    </a>
                                    <a asp-controller="CollectorFeedSources" asp-action="Delete" asp-route-id="@feedSource.Id" class="btn btn-sm btn-outline-danger">
                                        <i class="bi bi-trash"></i> Remove
                                    </a>
                                </td>
                            </tr>
                        }
                    </tbody>
                </table>
            </div>
        }
    </div>
</div>

<!-- YouTube Channels Section -->
<div class="card mb-4">
    <div class="card-header d-flex justify-content-between align-items-center">
        <h3 class="mb-0">
            <i class="bi bi-youtube me-2"></i>YouTube Channels
        </h3>
        <a asp-controller="CollectorYouTubeChannels" asp-action="Add" class="btn btn-primary">
            <i class="bi bi-plus-circle me-1"></i>Add YouTube Channel
        </a>
    </div>
    <div class="card-body">
        @if (Model.YouTubeChannels.Count == 0)
        {
            <p class="text-muted mb-0">No YouTube channels configured. Click "Add YouTube Channel" to get started.</p>
        }
        else
        {
            <div class="table-responsive">
                <table class="table table-hover">
                    <thead class="table-dark">
                        <tr>
                            <th>Display Name</th>
                            <th>Channel ID</th>
                            <th>Status</th>
                            <th>Actions</th>
                        </tr>
                    </thead>
                    <tbody>
                        @foreach (var channel in Model.YouTubeChannels)
                        {
                            <tr>
                                <td>@channel.DisplayName</td>
                                <td><code>@channel.ChannelId</code></td>
                                <td>
                                    <span class="badge @(channel.IsActive ? "text-bg-success" : "text-bg-secondary")">
                                        @(channel.IsActive ? "Active" : "Inactive")
                                    </span>
                                </td>
                                <td>
                                    <a asp-controller="CollectorYouTubeChannels" asp-action="Edit" asp-route-id="@channel.Id" class="btn btn-sm btn-outline-primary">
                                        <i class="bi bi-pencil"></i> Edit
                                    </a>
                                    <a asp-controller="CollectorYouTubeChannels" asp-action="Delete" asp-route-id="@channel.Id" class="btn btn-sm btn-outline-danger">
                                        <i class="bi bi-trash"></i> Remove
                                    </a>
                                </td>
                            </tr>
                        }
                    </tbody>
                </table>
            </div>
        }
    </div>
</div>

<!-- Speaking Engagements Section -->
<div class="card mb-4">
    <div class="card-header d-flex justify-content-between align-items-center">
        <h3 class="mb-0">
            <i class="bi bi-mic-fill me-2"></i>Speaking Engagements
        </h3>
        <a asp-controller="CollectorSpeakingEngagements" asp-action="Add" class="btn btn-primary">
            <i class="bi bi-plus-circle me-1"></i>Add Speaking Engagement
        </a>
    </div>
    <div class="card-body">
        @if (Model.SpeakingEngagements.Count == 0)
        {
            <p class="text-muted mb-0">No speaking engagement sources configured. Click "Add Speaking Engagement" to get started.</p>
        }
        else
        {
            <div class="table-responsive">
                <table class="table table-hover">
                    <thead class="table-dark">
                        <tr>
                            <th>Display Name</th>
                            <th>File URL</th>
                            <th>Status</th>
                            <th>Actions</th>
                        </tr>
                    </thead>
                    <tbody>
                        @foreach (var engagement in Model.SpeakingEngagements)
                        {
                            <tr>
                                <td>@engagement.DisplayName</td>
                                <td>
                                    <a href="@engagement.SpeakingEngagementsFile" target="_blank" rel="noopener noreferrer"
                                       class="text-truncate d-inline-block" style="max-width:300px;" title="@engagement.SpeakingEngagementsFile">
                                        @engagement.SpeakingEngagementsFile
                                    </a>
                                </td>
                                <td>
                                    <span class="badge @(engagement.IsActive ? "text-bg-success" : "text-bg-secondary")">
                                        @(engagement.IsActive ? "Active" : "Inactive")
                                    </span>
                                </td>
                                <td>
                                    <a asp-controller="CollectorSpeakingEngagements" asp-action="Edit" asp-route-id="@engagement.Id" class="btn btn-sm btn-outline-primary">
                                        <i class="bi bi-pencil"></i> Edit
                                    </a>
                                    <a asp-controller="CollectorSpeakingEngagements" asp-action="Delete" asp-route-id="@engagement.Id" class="btn btn-sm btn-outline-danger">
                                        <i class="bi bi-trash"></i> Remove
                                    </a>
                                </td>
                            </tr>
                        }
                    </tbody>
                </table>
            </div>
        }
    </div>
</div>
