@model JosephGuadagno.Broadcasting.Web.Models.UserEventDispatcherMappingViewModel

@{
    ViewData["Title"] = "Delete Event Dispatcher Mapping";
}

<div class="container">
    <h1 class="display-4 mb-4 text-danger">Delete Event Dispatcher Mapping</h1>

    <div class="alert alert-warning" role="alert">
        <i class="bi bi-exclamation-triangle-fill me-2"></i>
        <strong>Warning:</strong> Are you sure you want to delete this event dispatcher mapping?
    </div>

    <div class="card">
        <div class="card-body">
            <dl class="row">
                <dt class="col-sm-3">Event Type</dt>
                <dd class="col-sm-9"><i class="bi @Model.EventTypeIcon me-2"></i>@Model.EventTypeDisplayName</dd>

                <dt class="col-sm-3">Platform</dt>
                <dd class="col-sm-9"><i class="bi @Model.SocialMediaPlatformIcon me-2"></i>@Model.SocialMediaPlatformName</dd>

                <dt class="col-sm-3">Active</dt>
                <dd class="col-sm-9">@(Model.IsActive ? "Yes" : "No")</dd>

                <dt class="col-sm-3">Created On</dt>
                <dd class="col-sm-9"><local-time value="@Model.CreatedOn" /></dd>
            </dl>
        </div>
    </div>

    <form asp-action="Delete" asp-controller="UserEventDispatcherMapping" asp-route-id="@Model.Id" method="post" class="mt-3">
        <input type="hidden" asp-for="Id" />
        <button type="submit" class="btn btn-danger" data-loading-text="Deleting...">
            <i class="bi bi-trash me-1"></i>Yes, Delete
        </button>
        <a asp-action="Index" asp-controller="UserEventDispatcherMapping" class="btn btn-secondary ms-2">
            <i class="bi bi-x-circle me-1"></i>Cancel
        </a>
    </form>
</div>
