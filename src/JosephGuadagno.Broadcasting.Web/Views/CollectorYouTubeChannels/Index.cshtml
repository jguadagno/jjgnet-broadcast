@model List<JosephGuadagno.Broadcasting.Web.Models.UserCollectorYouTubeChannelViewModel>
@{
    ViewData["Title"] = "YouTube Channels";

    string NextSortDirection(string col)
    {
        return (ViewBag.SortBy as string) == col && (bool)ViewBag.SortDescending ? "false" : "true";
    }

    string SortIcon(string col)
    {
        if ((ViewBag.SortBy as string) != col) return "<i class=\"bi bi-sort\"></i>";
        return (bool)ViewBag.SortDescending ? "<i class=\"bi bi-sort-down\"></i>" : "<i class=\"bi bi-sort-up\"></i>";
    }
}

<div class="d-flex justify-content-between align-items-center mb-3">
    <h1><i class="bi bi-youtube me-2"></i>YouTube Channels</h1>
    @if (User.IsInRole(RoleNames.Contributor) ||
         User.IsInRole(RoleNames.Administrator) ||
         User.IsInRole(RoleNames.SiteAdministrator))
    {
        <a asp-action="Add" asp-controller="CollectorYouTubeChannels" class="btn btn-primary">
            <i class="bi bi-plus-circle me-1"></i>Add New
        </a>
    }
</div>
<p class="lead">
    A list of all of the YouTube channels that you have configured
</p>

<form method="get" asp-action="Index" asp-controller="CollectorYouTubeChannels" class="mb-3 d-flex gap-2">
    <input type="hidden" name="sortBy" value="@ViewBag.SortBy" />
    <input type="hidden" name="sortDescending" value="@ViewBag.SortDescending" />
    <input type="text" name="filter" class="form-control" placeholder="Filter by display name or channel ID..." value="@ViewBag.Filter" />
    <button type="submit" class="btn btn-outline-secondary">Filter</button>
    @if (!string.IsNullOrEmpty(ViewBag.Filter as string))
    {
        <a asp-action="Index" asp-controller="CollectorYouTubeChannels" asp-route-sortBy="@ViewBag.SortBy" asp-route-sortDescending="@ViewBag.SortDescending" class="btn btn-outline-danger">Clear</a>
    }
</form>

@if (TempData["SuccessMessage"] != null)
{
    <div class="alert alert-success alert-dismissible fade show" role="alert">
        @TempData["SuccessMessage"]
        <button type="button" class="btn-close" data-bs-dismiss="alert" aria-label="Close"></button>
    </div>
}
@if (TempData["ErrorMessage"] != null)
{
    <div class="alert alert-danger alert-dismissible fade show" role="alert">
        @TempData["ErrorMessage"]
        <button type="button" class="btn-close" data-bs-dismiss="alert" aria-label="Close"></button>
    </div>
}

@if (Model.Count == 0)
{
    <p class="text-muted">No YouTube channels found.</p>
}
else
{
    <table class="table table-striped table-hover table-bordered">
        <thead class="table-dark">
        <tr>
            <th scope="col">
                <a asp-action="Index" asp-controller="CollectorYouTubeChannels" asp-route-sortBy="displayname" asp-route-sortDescending="@NextSortDirection("displayname")" asp-route-filter="@ViewBag.Filter" class="text-decoration-none text-white">
                    Display Name @Html.Raw(SortIcon("displayname"))
                </a>
            </th>
            <th scope="col">
                <a asp-action="Index" asp-controller="CollectorYouTubeChannels" asp-route-sortBy="channelid" asp-route-sortDescending="@NextSortDirection("channelid")" asp-route-filter="@ViewBag.Filter" class="text-decoration-none text-white">
                    Channel ID @Html.Raw(SortIcon("channelid"))
                </a>
            </th>
            <th scope="col">
                <a asp-action="Index" asp-controller="CollectorYouTubeChannels" asp-route-sortBy="resultsperpage" asp-route-sortDescending="@NextSortDirection("resultsperpage")" asp-route-filter="@ViewBag.Filter" class="text-decoration-none text-white">
                    Results Per Page @Html.Raw(SortIcon("resultsperpage"))
                </a>
            </th>
            <th scope="col">
                <a asp-action="Index" asp-controller="CollectorYouTubeChannels" asp-route-sortBy="isactive" asp-route-sortDescending="@NextSortDirection("isactive")" asp-route-filter="@ViewBag.Filter" class="text-decoration-none text-white">
                    Active @Html.Raw(SortIcon("isactive"))
                </a>
            </th>
            <th scope="col">
                <a asp-action="Index" asp-controller="CollectorYouTubeChannels" asp-route-sortBy="createdon" asp-route-sortDescending="@NextSortDirection("createdon")" asp-route-filter="@ViewBag.Filter" class="text-decoration-none text-white">
                    Created On @Html.Raw(SortIcon("createdon"))
                </a>
            </th>
            <th scope="col" class="col-2">&nbsp;</th>
        </tr>
        </thead>
        <tbody>
        @foreach (var item in Model)
        {
            <tr>
                <td>@item.DisplayName</td>
                <td><code>@item.ChannelId</code></td>
                <td>@item.ResultSetPageSize</td>
                <td>
                    @if (item.IsActive)
                    {
                        <span class="badge bg-success"><i class="bi bi-check-circle me-1"></i>Active</span>
                    }
                    else
                    {
                        <span class="badge bg-secondary"><i class="bi bi-x-circle me-1"></i>Inactive</span>
                    }
                </td>
                <td>@item.CreatedOn.ToString("g")</td>
                <td class="text-end">
                    <a asp-action="Details" asp-controller="CollectorYouTubeChannels" asp-route-id="@item.Id" class="btn btn-sm btn-outline-secondary">
                        <i class="bi bi-eye"></i>
                    </a>
                    @if (User.IsInRole(RoleNames.Contributor) ||
                         User.IsInRole(RoleNames.Administrator) ||
                         User.IsInRole(RoleNames.SiteAdministrator))
                    {
                        <a asp-action="Edit" asp-controller="CollectorYouTubeChannels" asp-route-id="@item.Id" class="btn btn-sm btn-warning">
                            <i class="bi bi-pencil"></i>
                        </a>
                        <a asp-action="Delete" asp-controller="CollectorYouTubeChannels" asp-route-id="@item.Id" class="btn btn-sm btn-danger">
                            <i class="bi bi-trash"></i>
                        </a>
                    }
                </td>
            </tr>
        }
        </tbody>
    </table>
}

<partial name="_PaginationPartial" />
