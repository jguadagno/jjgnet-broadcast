@model JosephGuadagno.Broadcasting.Web.Models.UserCollectorYouTubeChannelViewModel
@{
    ViewData["Title"] = "YouTube Channel Details";
}

<div class="container">
    <h1 class="display-4 mb-4">YouTube Channel Details</h1>

    <div class="card">
        <div class="card-body">
            <dl class="row">
                <dt class="col-sm-3">Display Name</dt>
                <dd class="col-sm-9">@Model.DisplayName</dd>

                <dt class="col-sm-3">Channel ID</dt>
                <dd class="col-sm-9"><code>@Model.ChannelId</code></dd>

                <dt class="col-sm-3">Playlist ID</dt>
                <dd class="col-sm-9">
                    @if (!string.IsNullOrEmpty(Model.PlaylistId))
                    {
                        <code>@Model.PlaylistId</code>
                    }
                    else
                    {
                        <span class="text-muted">Not set (uses channel default)</span>
                    }
                </dd>

                <dt class="col-sm-3">API Key</dt>
                <dd class="col-sm-9">
                    @if (!string.IsNullOrEmpty(Model.ApiKey))
                    {
                        <span class="text-muted fst-italic">**** (stored securely)</span>
                    }
                    else
                    {
                        <span class="text-muted">Not set</span>
                    }
                </dd>

                <dt class="col-sm-3">Results Per Page</dt>
                <dd class="col-sm-9">@Model.ResultSetPageSize</dd>

                <dt class="col-sm-3">Active</dt>
                <dd class="col-sm-9">
                    @if (Model.IsActive)
                    {
                        <span class="badge bg-success"><i class="bi bi-check-circle me-1"></i>Active</span>
                    }
                    else
                    {
                        <span class="badge bg-secondary"><i class="bi bi-x-circle me-1"></i>Inactive</span>
                    }
                </dd>

                <dt class="col-sm-3">Created On</dt>
                <dd class="col-sm-9">@Model.CreatedOn.ToString("F")</dd>

                <dt class="col-sm-3">Last Updated</dt>
                <dd class="col-sm-9">@Model.LastUpdatedOn.ToString("F")</dd>
            </dl>
        </div>
    </div>

    <div class="mt-3">
        <a asp-action="Index" asp-controller="CollectorYouTubeChannels" class="btn btn-secondary">
            <i class="bi bi-arrow-left me-1"></i>Back to List
        </a>
        @if (User.IsInRole(RoleNames.Contributor) ||
             User.IsInRole(RoleNames.Administrator) ||
             User.IsInRole(RoleNames.SiteAdministrator))
        {
            <a asp-action="Edit" asp-controller="CollectorYouTubeChannels" asp-route-id="@Model.Id" class="btn btn-warning ms-2">
                <i class="bi bi-pencil me-1"></i>Edit
            </a>
            <a asp-action="Delete" asp-controller="CollectorYouTubeChannels" asp-route-id="@Model.Id" class="btn btn-danger ms-2">
                <i class="bi bi-trash me-1"></i>Delete
            </a>
        }
    </div>
</div>
