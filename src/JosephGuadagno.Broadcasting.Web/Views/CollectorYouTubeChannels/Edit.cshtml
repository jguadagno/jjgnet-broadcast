@model JosephGuadagno.Broadcasting.Web.Models.UserCollectorYouTubeChannelViewModel
@{
    ViewData["Title"] = "Edit YouTube Channel";
}

<div class="container">
    <h1 class="display-4 mb-4">Edit YouTube Channel</h1>

    <div class="card">
        <div class="card-body">
            <form asp-action="Edit" asp-controller="CollectorYouTubeChannels" method="post">
                <div asp-validation-summary="ModelOnly" class="alert alert-danger" role="alert"></div>
                <input type="hidden" asp-for="Id" />

                <input type="hidden" asp-for="HasApiKey" />
                <div class="mb-3">
                    <label asp-for="DisplayName" class="form-label"></label>
                    <input asp-for="DisplayName" class="form-control" />
                    <span asp-validation-for="DisplayName" class="text-danger"></span>
                </div>

                <div class="mb-3">
                    <label asp-for="ChannelId" class="form-label"></label>
                    <input asp-for="ChannelId" class="form-control" />
                    <span asp-validation-for="ChannelId" class="text-danger"></span>
                </div>

                <div class="mb-3">
                    <label asp-for="PlaylistId" class="form-label"></label>
                    <input asp-for="PlaylistId" class="form-control" />
                    <span asp-validation-for="PlaylistId" class="text-danger"></span>
                    <div class="form-text">Optional. Leave blank to use the channel's default uploads playlist.</div>
                </div>

                <div class="mb-3">
                    <label asp-for="ApiKey" class="form-label"></label>
                    @if (!Model.HasApiKey)
                    {
                        <span class="text-danger">*</span>
                    }
                    @if (Model.HasApiKey)
                    {
                        <input asp-for="ApiKey" class="form-control" type="password" autocomplete="new-password" />
                    }
                    else
                    {
                        <input asp-for="ApiKey" class="form-control" type="password" autocomplete="new-password" required />
                    }
                    <span asp-validation-for="ApiKey" class="text-danger"></span>
                    @if (Model.HasApiKey)
                    {
                        <div class="form-text text-muted">
                            <i class="bi bi-check-circle-fill text-success"></i> An API key is currently stored. Leave blank to keep the existing key.
                        </div>
                    }
                    else
                    {
                        <div class="form-text text-danger">
                            <i class="bi bi-exclamation-triangle-fill"></i> No API key is stored. An API key is required.
                        </div>
                    }
                </div>

                <div class="mb-3">
                    <label asp-for="ResultSetPageSize" class="form-label"></label>
                    <input asp-for="ResultSetPageSize" class="form-control" type="number" min="1" max="200" />
                    <span asp-validation-for="ResultSetPageSize" class="text-danger"></span>
                    <div class="form-text">Number of results to return per YouTube API page (1–200).</div>
                </div>

                <div class="mb-3 form-check">
                    <input asp-for="IsActive" class="form-check-input" />
                    <label asp-for="IsActive" class="form-check-label">Active</label>
                </div>

                <div class="mt-4">
                    <button type="submit" class="btn btn-primary">
                        <i class="bi bi-floppy me-1"></i>Save
                    </button>
                    <a asp-action="Index" asp-controller="CollectorYouTubeChannels" class="btn btn-secondary ms-2">
                        <i class="bi bi-x-circle me-1"></i>Cancel
                    </a>
                </div>
            </form>
        </div>
    </div>
</div>

@section Scripts {
    @{ await Html.RenderPartialAsync("_ValidationScriptsPartial"); }
}
