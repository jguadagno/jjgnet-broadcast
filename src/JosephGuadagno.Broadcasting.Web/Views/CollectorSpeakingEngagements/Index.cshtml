@model List<JosephGuadagno.Broadcasting.Web.Models.UserCollectorSpeakingEngagementViewModel>
@{
    ViewData["Title"] = "Speaking Engagements";

    string NextSortDirection(string col)
    {
        return (ViewBag.SortBy as string) == col && (bool)ViewBag.SortDescending ? "false" : "true";
    }

    string SortIcon(string col)
    {
        if ((ViewBag.SortBy as string) != col) return "";
        return (bool)ViewBag.SortDescending
            ? "<i class=\"bi bi-sort-alpha-up\"></i>"
            : "<i class=\"bi bi-sort-alpha-down\"></i>";
    }
}

<div class="d-flex justify-content-between align-items-center mb-3">
    <h1><i class="fa-solid fa-person-chalkboard me-2"></i>Speaking Engagements</h1>
    @if (User.IsInRole(RoleNames.Contributor) ||
         User.IsInRole(RoleNames.Administrator) ||
         User.IsInRole(RoleNames.SiteAdministrator))
    {
        <a asp-action="Add" asp-controller="CollectorSpeakingEngagements" class="btn btn-primary">
            <i class="bi bi-plus-circle me-1"></i>Add New
        </a>
    }
</div>
<p class="lead">
    A list of all of the speaking engagements sources that have been configured
</p>

<form method="get" asp-action="Index" asp-controller="CollectorSpeakingEngagements" class="mb-3 d-flex gap-2">
    <input type="hidden" name="sortBy" value="@ViewBag.SortBy" />
    <input type="hidden" name="sortDescending" value="@ViewBag.SortDescending" />
    <input type="text" name="filter" class="form-control" placeholder="Filter by display name or URL..." value="@ViewBag.Filter" />
    <button type="submit" class="btn btn-outline-secondary" data-loading-text="Searching...">Filter</button>
    @if (!string.IsNullOrEmpty(ViewBag.Filter as string))
    {
        <a asp-action="Index" asp-controller="CollectorSpeakingEngagements" asp-route-sortBy="@ViewBag.SortBy" asp-route-sortDescending="@ViewBag.SortDescending" class="btn btn-outline-danger">Clear</a>
    }
</form>

@if (Model.Count == 0)
{
    <p class="text-muted">No speaking engagement sources found.</p>
}
else
{
	<table class="table table-striped table-hover table-bordered">
		<thead>
        <tr>
            <th scope="col">
                <a asp-action="Index" asp-controller="CollectorSpeakingEngagements" asp-route-sortBy="displayname" asp-route-sortDescending="@NextSortDirection("displayname")" asp-route-filter="@ViewBag.Filter" class="text-decoration-none text-body">
                    Display Name @Html.Raw(SortIcon("displayname"))
                </a>
            </th>
            <th scope="col">
                <a asp-action="Index" asp-controller="CollectorSpeakingEngagements" asp-route-sortBy="speakingengagementsfile" asp-route-sortDescending="@NextSortDirection("speakingengagementsfile")" asp-route-filter="@ViewBag.Filter" class="text-decoration-none text-body">
                    File URL @Html.Raw(SortIcon("speakingengagementsfile"))
                </a>
            </th>
            <th scope="col">
                <a asp-action="Index" asp-controller="CollectorSpeakingEngagements" asp-route-sortBy="isactive" asp-route-sortDescending="@NextSortDirection("isactive")" asp-route-filter="@ViewBag.Filter" class="text-decoration-none text-body">
                    Active @Html.Raw(SortIcon("isactive"))
                </a>
            </th>
            <th scope="col">
                <a asp-action="Index" asp-controller="CollectorSpeakingEngagements" asp-route-sortBy="createdon" asp-route-sortDescending="@NextSortDirection("createdon")" asp-route-filter="@ViewBag.Filter" class="text-decoration-none text-body">
                    Created On @Html.Raw(SortIcon("createdon"))
                </a>
            </th>
            <th scope="col" class="col-2 text-end">&nbsp;</th>
        </tr>
        </thead>
        <tbody>
        @foreach (var item in Model)
        {
            <tr>
                <td>@item.DisplayName</td>
                <td>
                    <a href="@item.SpeakingEngagementsFile" target="_blank" rel="noopener noreferrer" class="text-truncate d-inline-block" style="max-width:300px;" title="@item.SpeakingEngagementsFile">
                        @item.SpeakingEngagementsFile
                    </a>
                </td>
                <td>
                    @if (item.IsActive)
                    {
                        <i class="bi bi-check-circle-fill text-success fs-5" title="Active"></i>
                    }
                    else
                    {
                        <i class="bi bi-x-circle-fill text-danger fs-5" title="Inactive"></i>
                    }
                </td>
                <td><local-time value="@item.CreatedOn" /></td>
                <td class="text-end">
                    <a asp-action="Details" asp-controller="CollectorSpeakingEngagements" asp-route-id="@item.Id" class="btn btn-sm btn-outline-primary" title="View">
                        <i class="bi bi-eye"></i>
                    </a>
                    @if (User.IsInRole(RoleNames.Contributor) ||
                         User.IsInRole(RoleNames.Administrator) ||
                         User.IsInRole(RoleNames.SiteAdministrator))
                    {
                        <a asp-action="Edit" asp-controller="CollectorSpeakingEngagements" asp-route-id="@item.Id" class="btn btn-sm btn-outline-primary" title="Edit">
                            <i class="bi bi-pencil-square"></i>
                        </a>
                        <form asp-action="ToggleActive" asp-controller="CollectorSpeakingEngagements" asp-route-id="@item.Id" method="post" class="d-inline">
                            @Html.AntiForgeryToken()
                            <button type="submit" class="btn btn-sm btn-warning"
                                    title="@(item.IsActive ? "Deactivate" : "Activate")">
                                <i class="bi @(item.IsActive ? "bi-toggle-off" : "bi-toggle-on")"></i>
                            </button>
                        </form>
                        <a asp-action="Delete" asp-controller="CollectorSpeakingEngagements" asp-route-id="@item.Id" class="btn btn-sm btn-danger" title="Delete">
                            <i class="bi bi-trash"></i>
                        </a>
                    }
                </td>
            </tr>
        }
        </tbody>
    </table>
}

<partial name="_PaginationPartial" />
@if (User.IsInRole(RoleNames.Contributor) ||
     User.IsInRole(RoleNames.Administrator) ||
     User.IsInRole(RoleNames.SiteAdministrator))
{
    <a asp-action="Add" asp-controller="CollectorSpeakingEngagements" class="btn btn-primary mt-2">
        <i class="bi bi-plus-circle me-1"></i>Add New
    </a>
}
