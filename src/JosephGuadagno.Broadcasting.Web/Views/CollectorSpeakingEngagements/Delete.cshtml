@model JosephGuadagno.Broadcasting.Web.Models.UserCollectorSpeakingEngagementViewModel
@{
    ViewData["Title"] = "Delete Speaking Engagement";
}

<div class="container">
    <h1 class="display-4 mb-4 text-danger">Delete Speaking Engagement</h1>

    <div class="alert alert-warning" role="alert">
        <i class="bi bi-exclamation-triangle-fill me-2"></i>
        <strong>Warning:</strong> Are you sure you want to delete this item?
    </div>

    <div class="card">
        <div class="card-body">
            <dl class="row">
                <dt class="col-sm-3">Display Name</dt>
                <dd class="col-sm-9">@Model.DisplayName</dd>

                <dt class="col-sm-3">Speaking Engagements File URL</dt>
                <dd class="col-sm-9">
                    <a href="@Model.SpeakingEngagementsFile" target="_blank" rel="noopener noreferrer">@Model.SpeakingEngagementsFile</a>
                </dd>

                <dt class="col-sm-3">Active</dt>
                <dd class="col-sm-9">@(Model.IsActive ? "Yes" : "No")</dd>

                <dt class="col-sm-3">Created On</dt>
                <dd class="col-sm-9">@Model.CreatedOn.ToString("F")</dd>
            </dl>
        </div>
    </div>

    <form asp-action="Delete" asp-controller="CollectorSpeakingEngagements" method="post" class="mt-3">
        <input type="hidden" asp-for="Id" />
        <button type="submit" class="btn btn-danger">
            <i class="bi bi-trash me-1"></i>Yes, Delete
        </button>
        <a asp-action="Index" asp-controller="CollectorSpeakingEngagements" class="btn btn-secondary ms-2">
            <i class="bi bi-x-circle me-1"></i>Cancel
        </a>
    </form>
</div>
