@model JosephGuadagno.Broadcasting.Web.Models.UserCollectorSpeakingEngagementViewModel
@{
    ViewData["Title"] = "Edit Speaking Engagement";
}

<div class="container">
    <h1 class="display-4 mb-4">Edit Speaking Engagement</h1>

    @if (TempData["ErrorMessage"] != null)
    {
        <div class="alert alert-danger alert-dismissible fade show" role="alert">
            @TempData["ErrorMessage"]
            <button type="button" class="btn-close" data-bs-dismiss="alert" aria-label="Close"></button>
        </div>
    }

    <div class="card">
        <div class="card-body">
            <form asp-action="Edit" asp-controller="CollectorSpeakingEngagements" method="post">
                <div asp-validation-summary="ModelOnly" class="alert alert-danger" role="alert"></div>
                <input type="hidden" asp-for="Id" />

                <div class="mb-3">
                    <label asp-for="DisplayName" class="form-label"></label>
                    <input asp-for="DisplayName" class="form-control" />
                    <span asp-validation-for="DisplayName" class="text-danger"></span>
                </div>

                <div class="mb-3">
                    <label asp-for="SpeakingEngagementsFile" class="form-label"></label>
                    <input asp-for="SpeakingEngagementsFile" class="form-control" type="url" />
                    <span asp-validation-for="SpeakingEngagementsFile" class="text-danger"></span>
                    <div class="form-text">URL to the JSON speaking engagements data file.</div>
                </div>

                <div class="mb-3 form-check">
                    <input asp-for="IsActive" class="form-check-input" />
                    <label asp-for="IsActive" class="form-check-label">Active</label>
                </div>

                <div class="mt-4">
                    <button type="submit" class="btn btn-primary">
                        <i class="bi bi-floppy me-1"></i>Save
                    </button>
                    <a asp-action="Index" asp-controller="CollectorSpeakingEngagements" class="btn btn-secondary ms-2">
                        <i class="bi bi-x-circle me-1"></i>Cancel
                    </a>
                </div>
            </form>
        </div>
    </div>
</div>

@section Scripts {
    @{ await Html.RenderPartialAsync("_ValidationScriptsPartial"); }
    <environment include="Development">
        <script>
            // Allow localhost URLs in development by overriding the url validator
            jQuery.validator.methods.url = jQuery.validator.methods.url2;
        </script>
    </environment>
}
