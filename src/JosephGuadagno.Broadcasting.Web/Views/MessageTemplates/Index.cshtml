@model List<JosephGuadagno.Broadcasting.Web.Models.MessageTemplateViewModel>

@{
    ViewData["Title"] = "Message Templates";
    var platforms = Model.GroupBy(t => t.Platform).OrderBy(g => g.Key).ToList();

    string NextSortDirection(string col)
    {
        return (ViewBag.SortBy as string) == col && (bool)ViewBag.SortDescending ? "false" : "true";
    }

    string SortIcon(string col)
    {
        if ((ViewBag.SortBy as string) != col) return "";
        return (bool)ViewBag.SortDescending ? " <i class=\"bi bi-arrow-down\"></i>" : " <i class=\"bi bi-arrow-up\"></i>";
    }
}

<div class="d-flex justify-content-between mb-3">
    <h1><i class="bi bi-textarea-t me-2"></i>Message Templates</h1>
</div>
<p class="lead">
    Scriban templates used to render broadcast messages for each platform. Edit the template body to customize how posts are formatted.
</p>

<form method="get" asp-action="Index" asp-controller="MessageTemplates" class="mb-3 d-flex gap-2">
    <input type="hidden" name="sortBy" value="@ViewBag.SortBy" />
    <input type="hidden" name="sortDescending" value="@ViewBag.SortDescending" />
    <input type="text" name="filter" class="form-control" placeholder="Filter by message type or description..." value="@ViewBag.Filter" />
    <select name="selectedPlatform" class="form-select w-auto" onchange="this.form.submit()">
        <option value="">All Platforms</option>
        @foreach (var p in (List<string>)ViewBag.Platforms)
        {
            <option value="@p" selected="@(p == (string)ViewBag.SelectedPlatform)">@p</option>
        }
    </select>
    <button type="submit" class="btn btn-outline-secondary">Filter</button>
    @if (!string.IsNullOrEmpty(ViewBag.Filter as string) || !string.IsNullOrEmpty(ViewBag.SelectedPlatform as string))
    {
        <a asp-action="Index" asp-controller="MessageTemplates" asp-route-sortBy="@ViewBag.SortBy" asp-route-sortDescending="@ViewBag.SortDescending" class="btn btn-outline-danger">Clear</a>
    }
</form>

@foreach (var platform in platforms)
{
    <h4 class="mt-4 mb-2">
        <i class="bi @GetSocialIcon(platform.Key) me-2"></i>@platform.Key
    </h4>
    <table class="table table-striped table-hover table-bordered">
        <thead>
        <tr>
            <th scope="col" class="col-2">
                <a asp-action="Index" asp-controller="MessageTemplates" asp-route-sortBy="messagetype" asp-route-sortDescending="@NextSortDirection("messagetype")" asp-route-filter="@ViewBag.Filter" asp-route-selectedPlatform="@ViewBag.SelectedPlatform" class="text-decoration-none text-body">
                    Message Type @Html.Raw(SortIcon("messagetype"))
                </a>
            </th>
            <th scope="col" class="col-3">Description</th>
            <th scope="col">Template</th>
            <th scope="col" class="col-1">&nbsp;</th>
        </tr>
        </thead>
        <tbody>
        @foreach (var template in platform.OrderBy(t => t.MessageType))
        {
            var truncated = template.Template.Length > 80
                ? template.Template.Substring(0, 80) + "…"
                : template.Template;
            <tr>
                <td>@template.MessageType</td>
                <td>@template.Description</td>
                <td>
                    <span title="@template.Template" data-bs-toggle="tooltip" data-bs-placement="top">@truncated</span>
                </td>
                <td>
                    <a asp-action="Edit" asp-controller="MessageTemplates"
                       asp-route-platform="@template.Platform"
                       asp-route-messageType="@template.MessageType"
                       class="btn btn-outline-secondary btn-sm">
                        <i class="bi bi-pencil"></i>
                    </a>
                </td>
            </tr>
        }
        </tbody>
    </table>
}

<partial name="_PaginationPartial" />

@section Scripts {
    <script>
        // Enable Bootstrap tooltips for truncated template preview
        document.addEventListener('DOMContentLoaded', function () {
            var tooltipEls = document.querySelectorAll('[data-bs-toggle="tooltip"]');
            tooltipEls.forEach(function (el) { new bootstrap.Tooltip(el); });
        });
    </script>
}

@functions {

    /// <summary>
    /// Returns the icon for the social platform
    /// </summary>
    /// <param name="platform">The platform name</param>
    /// <returns></returns>
    public string GetSocialIcon(string platform)
    {
        return platform switch
        {
            "Facebook" => "bi-facebook",
            "Twitter" => "bi-twitter-x",
            "LinkedIn" => "bi-linkedin",
            "Bluesky" => "bi-bluesky",
            _ => "bi-broadcast"
        };
    }
}
