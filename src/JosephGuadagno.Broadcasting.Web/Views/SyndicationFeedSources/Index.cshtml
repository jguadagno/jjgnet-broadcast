@model List<JosephGuadagno.Broadcasting.Web.Models.SyndicationFeedSourceViewModel>
@{
    ViewData["Title"] = "Syndication Feed Sources";

    string NextSortDirection(string col)
    {
        return (ViewBag.SortBy as string) == col && (bool)ViewBag.SortDescending ? "false" : "true";
    }

    string SortIcon(string col)
    {
        if ((ViewBag.SortBy as string) != col) return "";
        return (bool)ViewBag.SortDescending ? " <i class=\"bi bi-arrow-down\"></i>" : " <i class=\"bi bi-arrow-up\"></i>";
    }
}
<div class="text-center">
    <h1 class="display-4">Syndication Feed Sources</h1>

    <form method="get" asp-action="Index" asp-controller="SyndicationFeedSources" class="mb-3 d-flex gap-2">
        <input type="hidden" name="sortBy" value="@ViewBag.SortBy" />
        <input type="hidden" name="sortDescending" value="@ViewBag.SortDescending" />
        <input type="text" name="filter" class="form-control" placeholder="Filter by title or author..." value="@ViewBag.Filter" />
        <button type="submit" class="btn btn-outline-secondary">Filter</button>
        @if (!string.IsNullOrEmpty(ViewBag.Filter as string))
        {
            <a asp-action="Index" asp-controller="SyndicationFeedSources" asp-route-sortBy="@ViewBag.SortBy" asp-route-sortDescending="@ViewBag.SortDescending" class="btn btn-outline-danger">Clear</a>
        }
    </form>

    @if (TempData["SuccessMessage"] != null)
    {
        <div class="alert alert-success alert-dismissible fade show" role="alert">
            @TempData["SuccessMessage"]
            <button type="button" class="btn-close" data-bs-dismiss="alert" aria-label="Close"></button>
        </div>
    }
    @if (TempData["ErrorMessage"] != null)
    {
        <div class="alert alert-danger alert-dismissible fade show" role="alert">
            @TempData["ErrorMessage"]
            <button type="button" class="btn-close" data-bs-dismiss="alert" aria-label="Close"></button>
        </div>
    }

    @if (Model.Count == 0)
    {
        <p class="text-muted">No syndication feed sources found.</p>
    }
    else
    {
        <table class="table table-striped">
            <thead class="table-dark">
            <tr>
                <th scope="col">
                    <a asp-action="Index" asp-controller="SyndicationFeedSources" asp-route-sortBy="title" asp-route-sortDescending="@NextSortDirection("title")" asp-route-filter="@ViewBag.Filter" class="text-decoration-none text-white">
                        Title@Html.Raw(SortIcon("title"))
                    </a>
                </th>
                <th scope="col">
                    <a asp-action="Index" asp-controller="SyndicationFeedSources" asp-route-sortBy="author" asp-route-sortDescending="@NextSortDirection("author")" asp-route-filter="@ViewBag.Filter" class="text-decoration-none text-white">
                        Author@Html.Raw(SortIcon("author"))
                    </a>
                </th>
                <th scope="col">
                    <a asp-action="Index" asp-controller="SyndicationFeedSources" asp-route-sortBy="publicationdate" asp-route-sortDescending="@NextSortDirection("publicationdate")" asp-route-filter="@ViewBag.Filter" class="text-decoration-none text-white">
                        Publication Date@Html.Raw(SortIcon("publicationdate"))
                    </a>
                </th>
                <th scope="col">
                    <a asp-action="Index" asp-controller="SyndicationFeedSources" asp-route-sortBy="addedon" asp-route-sortDescending="@NextSortDirection("addedon")" asp-route-filter="@ViewBag.Filter" class="text-decoration-none text-white">
                        Added On@Html.Raw(SortIcon("addedon"))
                    </a>
                </th>
                <th scope="col" class="col-2">&nbsp;</th>
            </tr>
            </thead>
            <tbody>
            @foreach (var source in Model)
            {
                <tr>
                    <td>
                        @source.Title
                        @if (!string.IsNullOrEmpty(source.Url))
                        {
                            <a href="@source.Url" title="@source.Url" target="_blank"><i class="bi bi-box-arrow-up-right"></i></a>
                        }
                    </td>
                    <td>@source.Author</td>
                    <td><local-time value="@source.PublicationDate" /></td>
                    <td><local-time value="@source.AddedOn" /></td>
                    <td class="text-end">
                        <a asp-action="Details" asp-controller="SyndicationFeedSources" asp-route-id="@source.Id" class="btn btn-outline-secondary">
                            <i class="bi bi-eye"></i>
                        </a>
                        @if (User.IsInRole(JosephGuadagno.Broadcasting.Domain.Constants.RoleNames.Administrator) ||
                             User.IsInRole(JosephGuadagno.Broadcasting.Domain.Constants.RoleNames.SiteAdministrator))
                        {
                            <a asp-action="Delete" asp-controller="SyndicationFeedSources" asp-route-id="@source.Id" class="btn btn-danger">
                                <i class="bi bi-trash"></i>
                            </a>
                        }
                    </td>
                </tr>
            }
            </tbody>
        </table>
    }

    <partial name="_PaginationPartial" />

    @if (User.IsInRole(JosephGuadagno.Broadcasting.Domain.Constants.RoleNames.Contributor) ||
         User.IsInRole(JosephGuadagno.Broadcasting.Domain.Constants.RoleNames.Administrator) ||
         User.IsInRole(JosephGuadagno.Broadcasting.Domain.Constants.RoleNames.SiteAdministrator))
    {
        <a asp-action="Add" asp-controller="SyndicationFeedSources" class="btn btn-primary">
            <i class="bi bi-rss me-2"></i>Add New Syndication Feed Source
        </a>
    }
</div>