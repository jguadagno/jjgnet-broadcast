@model JosephGuadagno.Broadcasting.Web.Models.PublishersAggregateViewModel

@{
    ViewData["Title"] = "Publisher Settings";
}

<div class="d-flex flex-column flex-lg-row justify-content-between align-items-lg-center gap-3 mb-4">
    <div>
        <h1 class="mb-1">
            <i class="bi bi-broadcast-pin me-2"></i>Publisher Settings
        </h1>
        <p class="text-muted mb-0">
            Configure the social accounts this application can publish to on your behalf.
        </p>
    </div>
</div>

<div class="row row-cols-1 row-cols-md-2 g-4">
    @{
        var platforms = new[]
        {
            new { Name = "Bluesky", Icon = "bi-cloud", IsConfigured = Model?.Bluesky is not null, IsEnabled = Model?.Bluesky?.IsEnabled ?? false, Controller = "PublisherBlueskySettings" },
            new { Name = "Twitter / X", Icon = "bi-twitter-x", IsConfigured = Model?.Twitter is not null, IsEnabled = Model?.Twitter?.IsEnabled ?? false, Controller = "PublisherTwitterSettings" },
            new { Name = "LinkedIn", Icon = "bi-linkedin", IsConfigured = Model?.LinkedIn is not null, IsEnabled = Model?.LinkedIn?.IsEnabled ?? false, Controller = "PublisherLinkedInSettings" },
            new { Name = "Facebook", Icon = "bi-facebook", IsConfigured = Model?.Facebook is not null, IsEnabled = Model?.Facebook?.IsEnabled ?? false, Controller = "PublisherFacebookSettings" }
        };
    }
    @foreach (var platform in platforms)
    {
        <div class="col">
            <div class="card h-100 shadow-sm">
                <div class="card-header d-flex justify-content-between align-items-center">
                    <div>
                        <i class="bi @platform.Icon me-2"></i>
                        <strong>@platform.Name</strong>
                    </div>
                    @if (platform.IsConfigured)
                    {
                        <span class="badge @(platform.IsEnabled ? "text-bg-success" : "text-bg-secondary")">
                            @(platform.IsEnabled ? "Enabled" : "Disabled")
                        </span>
                    }
                    else
                    {
                        <span class="badge text-bg-light text-muted">Not configured</span>
                    }
                </div>
                <div class="card-body d-flex justify-content-end align-items-end">
                    <a asp-controller="@platform.Controller" asp-action="Index" class="btn btn-outline-primary btn-sm">
                        <i class="bi bi-gear me-1"></i>Settings
                    </a>
                </div>
            </div>
        </div>
    }
</div>
