@model JosephGuadagno.Broadcasting.Web.Models.UserCollectorFeedSourceViewModel
@{
    ViewData["Title"] = "Add Feed Source";
}

<div class="container">
    <h1 class="display-4 mb-4">Add Feed Source</h1>

    @if (TempData["ErrorMessage"] != null)
    {
        <div class="alert alert-danger alert-dismissible fade show" role="alert">
            @TempData["ErrorMessage"]
            <button type="button" class="btn-close" data-bs-dismiss="alert" aria-label="Close"></button>
        </div>
    }

    <div class="card">
        <div class="card-body">
            <form asp-action="Add" asp-controller="CollectorFeedSources" method="post">
                <div asp-validation-summary="ModelOnly" class="alert alert-danger" role="alert"></div>

                <div class="mb-3">
                    <label asp-for="DisplayName" class="form-label"></label>
                    <input asp-for="DisplayName" class="form-control" />
                    <span asp-validation-for="DisplayName" class="text-danger"></span>
                </div>

                <div class="mb-3">
                    <label asp-for="FeedUrl" class="form-label"></label>
                    <input asp-for="FeedUrl" class="form-control" />
                    <span asp-validation-for="FeedUrl" class="text-danger"></span>
                </div>

                <div class="mb-3 form-switch">
                    <input asp-for="IsActive" class="form-check-input" />
                    <label asp-for="IsActive" class="form-check-label">Active</label>
                </div>

                <div class="mt-4">
                    <button type="submit" class="btn btn-primary">
                        <i class="bi bi-plus-circle me-1"></i>Add
                    </button>
                    <a asp-action="Index" asp-controller="CollectorFeedSources" class="btn btn-secondary ms-2">
                        <i class="bi bi-x-circle me-1"></i>Cancel
                    </a>
                </div>
            </form>
        </div>
    </div>
</div>
 
@section Scripts {
    @{ await Html.RenderPartialAsync("_ValidationScriptsPartial"); }
    <environment include="Development">
        <script>
            // Allow localhost URLs in development by overriding the url validator
            jQuery.validator.methods.url = jQuery.validator.methods.url2;
        </script>
    </environment>
}
