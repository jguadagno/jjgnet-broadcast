@if (User.Identity is not null && User.Identity.IsAuthenticated)
{
		<ul class="navbar-nav">
				<li class="nav-item dropdown">
						<a class="nav-link dropdown-toggle" href="#" role="button" data-bs-toggle="dropdown"
						   aria-expanded="false">
								<i class="bi bi-person-circle me-1"></i>
								@User.Identity.Name
						</a>
						<ul class="dropdown-menu">
								@if (User.IsInRole(RoleNames.SiteAdministrator) || User.IsInRole(RoleNames.Administrator) || User.IsInRole(RoleNames.Contributor))
								{

										<li>
												<a class="dropdown-item" asp-area="" asp-controller="MessageTemplates"
												   asp-action="Index">
														<i class="bi bi-textarea-t me-2"></i>Message Templates
												</a>
										</li>
										<li>
												<hr class="dropdown-divider">
										</li>
										<li><h6 class="dropdown-header">Collector Settings</h6></li>
										<li><a class="dropdown-item" asp-controller="CollectorSettings" asp-action="Index">
											<i class="bi @CollectorIcons.Collection me-2"></i>All Collector Settings</a></li>
										<li><a class="dropdown-item" asp-controller="CollectorFeedSources" asp-action="Index"><i
																class="bi @CollectorIcons.FeedSource.Icon me-2"></i>Feed Sources</a></li>
										<li><a class="dropdown-item" asp-controller="CollectorSpeakingEngagements" asp-action="Index"><i
																class="fa-solid fa-person-chalkboard me-2"></i>Speaking Engagements</a></li>
										<li><a class="dropdown-item" asp-controller="CollectorYouTubeChannels" asp-action="Index"><i
																class="bi @CollectorIcons.YouTubeChannel.Icon me-2"></i>YouTube Channels</a></li>
										<li>
												<hr class="dropdown-divider">
										</li>
										<li><h6 class="dropdown-header">Publisher Settings</h6></li>
                    <li><a class="dropdown-item" asp-controller="Publishers" asp-action="Index">
                        <i class="bi bi-broadcast-pin me-2"></i>All Publisher Settings</a></li>
                    <li><a class="dropdown-item" asp-controller="PublisherBlueskySettings" asp-action="Index">
                        <i class="bi bi-bluesky me-2"></i>Bluesky</a></li>
                    <li><a class="dropdown-item" asp-controller="PublisherFacebookSettings" asp-action="Index">
	                    <i class="bi bi-facebook me-2"></i>Facebook</a></li>
                    <li><a class="dropdown-item" asp-controller="PublisherLinkedInSettings" asp-action="Index">
                        <i class="bi bi-linkedin me-2"></i>LinkedIn</a></li>
                    <li><a class="dropdown-item" asp-controller="PublisherTwitterSettings" asp-action="Index">
	                    <i class="bi bi-twitter-x me-2"></i>Twitter / X</a></li>
                    <li><a class="dropdown-item" asp-controller="UserRandomPostSettings" asp-action="Index">
                        <i class="bi bi-shuffle me-2"></i>Random Post Settings</a></li>
                    <li><a class="dropdown-item" asp-controller="UserEventPublisherMapping" asp-action="Index">
                        <i class="bi bi-diagram-3 me-2"></i>Event Publisher Mappings</a></li>
                    <li>
												<hr class="dropdown-divider">
										</li>
								}
								@if (User.IsInRole(RoleNames.SiteAdministrator))
								{
										<li>
												<h6 class="dropdown-header">Platform Management</h6>
										</li>
										<li><a class="dropdown-item" asp-area="" asp-controller="SocialMediaPlatforms"
										       asp-action="Index">
														<i class="bi bi-share me-2"></i>Social Media Platforms
												</a></li>
										<li>
												<hr class="dropdown-divider">
										</li>
										<li>
												<h6 class="dropdown-header">Account Management</h6>
										</li>
										<li>
												<a class="dropdown-item" asp-area="" asp-controller="SiteAdmin" asp-action="Users">
														<i class="bi bi-people me-2"></i>Users
												</a>
										</li>
										<li>
												<hr class="dropdown-divider">
										</li>
								}
								<li>
										<a class="dropdown-item" asp-area="MicrosoftIdentity" asp-controller="Account"
										   asp-action="SignOut">
												<i class="bi bi-box-arrow-right me-2"></i>Sign out
										</a>
								</li>
						</ul>
				</li>
		</ul>
}
else
{
		<a class="nav-link" asp-area="MicrosoftIdentity" asp-controller="Account" asp-action="SignIn">Sign in</a>
}
