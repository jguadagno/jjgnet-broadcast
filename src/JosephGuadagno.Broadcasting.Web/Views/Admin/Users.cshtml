@model JosephGuadagno.Broadcasting.Web.Models.UserListViewModel

@{
    ViewData["Title"] = "User Management";
}

<h1>
    <i class="bi bi-people me-2"></i>User Management
</h1>

<div class="mt-4">
    <!-- Pending Users Section -->
    <div class="card mb-4">
        <div class="card-header bg-warning text-dark">
            <h3 class="mb-0">
                <i class="bi bi-hourglass-split me-2"></i>Pending Users 
                <span class="badge bg-dark">@Model.PendingUsers.Count</span>
            </h3>
        </div>
        <div class="card-body">
            @if (Model.PendingUsers.Any())
            {
                <div class="table-responsive">
                    <table class="table table-striped table-hover">
                        <thead>
                            <tr>
                                <th>Display Name</th>
                                <th>Email</th>
                                <th>Registered On</th>
                                <th>Actions</th>
                            </tr>
                        </thead>
                        <tbody>
                            @foreach (var user in Model.PendingUsers)
                            {
                                <tr id="user-@user.Id">
                                    <td>@user.DisplayName</td>
                                    <td>@user.Email</td>
                                    <td><local-time value="@user.CreatedAt" /></td>
                                    <td>
                                        <div class="btn-group" role="group">
                                            <form asp-action="ApproveUser" method="post" class="d-inline">
                                                @Html.AntiForgeryToken()
                                                <input type="hidden" name="userId" value="@user.Id" />
                                                <button type="submit" class="btn btn-sm btn-success" title="Approve User">
                                                    <i class="bi bi-check-circle me-1"></i>Approve
                                                </button>
                                            </form>
                                            <button type="button" class="btn btn-sm btn-danger" 
                                                    data-bs-toggle="collapse" 
                                                    data-bs-target="#reject-@user.Id" 
                                                    title="Reject User">
                                                <i class="bi bi-x-circle me-1"></i>Reject
                                            </button>
                                        </div>
                                        
                                        <!-- Rejection notes form (collapsible) -->
                                        <div class="collapse mt-2" id="reject-@user.Id">
                                            <div class="card card-body">
                                                <form asp-action="RejectUser" method="post">
                                                    @Html.AntiForgeryToken()
                                                    <input type="hidden" name="userId" value="@user.Id" />
                                                    <div class="mb-2">
                                                        <label class="form-label fw-bold">Rejection Notes (Required)</label>
                                                        <textarea name="rejectionNotes" 
                                                                  class="form-control" 
                                                                  rows="3" 
                                                                  placeholder="Please provide a reason for rejecting this user..."
                                                                  required></textarea>
                                                    </div>
                                                    <div class="d-flex gap-2">
                                                        <button type="submit" class="btn btn-sm btn-danger">
                                                            <i class="bi bi-send me-1"></i>Submit Rejection
                                                        </button>
                                                        <button type="button" 
                                                                class="btn btn-sm btn-secondary" 
                                                                data-bs-toggle="collapse" 
                                                                data-bs-target="#reject-@user.Id">
                                                            Cancel
                                                        </button>
                                                    </div>
                                                </form>
                                            </div>
                                        </div>
                                    </td>
                                </tr>
                            }
                        </tbody>
                    </table>
                </div>
            }
            else
            {
                <p class="text-muted mb-0">
                    <i class="bi bi-info-circle me-2"></i>No pending users.
                </p>
            }
        </div>
    </div>

    <!-- Approved Users Section -->
    <div class="card mb-4">
        <div class="card-header bg-success text-white">
            <h3 class="mb-0">
                <i class="bi bi-check-circle me-2"></i>Approved Users 
                <span class="badge bg-dark">@Model.ApprovedUsers.Count</span>
            </h3>
        </div>
        <div class="card-body">
            @if (Model.ApprovedUsers.Any())
            {
                <div class="table-responsive">
                    <table class="table table-striped table-hover">
                        <thead>
                            <tr>
                                <th>Display Name</th>
                                <th>Email</th>
                                <th>Registered On</th>
                            </tr>
                        </thead>
                        <tbody>
                            @foreach (var user in Model.ApprovedUsers)
                            {
                                <tr>
                                    <td>@user.DisplayName</td>
                                    <td>@user.Email</td>
                                    <td><local-time value="@user.CreatedAt" /></td>
                                </tr>
                            }
                        </tbody>
                    </table>
                </div>
            }
            else
            {
                <p class="text-muted mb-0">
                    <i class="bi bi-info-circle me-2"></i>No approved users.
                </p>
            }
        </div>
    </div>

    <!-- Rejected Users Section -->
    <div class="card mb-4">
        <div class="card-header bg-danger text-white">
            <h3 class="mb-0">
                <i class="bi bi-x-circle me-2"></i>Rejected Users 
                <span class="badge bg-dark">@Model.RejectedUsers.Count</span>
            </h3>
        </div>
        <div class="card-body">
            @if (Model.RejectedUsers.Any())
            {
                <div class="table-responsive">
                    <table class="table table-striped table-hover">
                        <thead>
                            <tr>
                                <th>Display Name</th>
                                <th>Email</th>
                                <th>Rejection Notes</th>
                                <th>Registered On</th>
                            </tr>
                        </thead>
                        <tbody>
                            @foreach (var user in Model.RejectedUsers)
                            {
                                <tr>
                                    <td>@user.DisplayName</td>
                                    <td>@user.Email</td>
                                    <td>
                                        @if (!string.IsNullOrEmpty(user.ApprovalNotes))
                                        {
                                            <span>@user.ApprovalNotes</span>
                                        }
                                        else
                                        {
                                            <em class="text-muted">No notes provided</em>
                                        }
                                    </td>
                                    <td><local-time value="@user.CreatedAt" /></td>
                                </tr>
                            }
                        </tbody>
                    </table>
                </div>
            }
            else
            {
                <p class="text-muted mb-0">
                    <i class="bi bi-info-circle me-2"></i>No rejected users.
                </p>
            }
        </div>
    </div>
</div>
