@model List<JosephGuadagno.Broadcasting.Web.Models.YouTubeItemViewModel>
@{
    ViewData["Title"] = "YouTube Sources";

    string NextSortDirection(string col)
    {
        return (ViewBag.SortBy as string) == col && (bool)ViewBag.SortDescending ? "false" : "true";
    }

    string SortIcon(string col)
    {
        if ((ViewBag.SortBy as string) != col) return "";
        return (bool)ViewBag.SortDescending ? " <i class=\"bi bi-arrow-down\"></i>" : " <i class=\"bi bi-arrow-up\"></i>";
    }
}
<div class="d-flex justify-content-between mb-3">
    <h1><i class="bi bi-youtube me-2"></i>YouTube Sources</h1>
</div>
<p class="lead">
    A list of all of the videos on YouTube that the system has retrieved
</p>

<form method="get" asp-action="Index" asp-controller="YouTubeItems" class="mb-3 d-flex gap-2">
    <input type="hidden" name="sortBy" value="@ViewBag.SortBy" />
    <input type="hidden" name="sortDescending" value="@ViewBag.SortDescending" />
    <input type="text" name="filter" class="form-control" placeholder="Filter by title or author..." value="@ViewBag.Filter" />
    <button type="submit" class="btn btn-outline-secondary" data-loading-text="Searching...">Filter</button>
    @if (!string.IsNullOrEmpty(ViewBag.Filter as string))
    {
        <a asp-action="Index" asp-controller="YouTubeItems" asp-route-sortBy="@ViewBag.SortBy" asp-route-sortDescending="@ViewBag.SortDescending" class="btn btn-outline-danger">Clear</a>
    }
</form>

@if (Model.Count == 0)
{
    <p class="text-muted">No YouTube sources found.</p>
}
else
{
    <table class="table table-striped table-hover table-bordered">
        <thead>
        <tr>
            <th scope="col">
                <a asp-action="Index" asp-controller="YouTubeItems" asp-route-sortBy="title" asp-route-sortDescending="@NextSortDirection("title")" asp-route-filter="@ViewBag.Filter" class="text-decoration-none text-body">
                    Title @Html.Raw(SortIcon("title"))
                </a>
            </th>
            <th scope="col">
                <a asp-action="Index" asp-controller="YouTubeItems" asp-route-sortBy="author" asp-route-sortDescending="@NextSortDirection("author")" asp-route-filter="@ViewBag.Filter" class="text-decoration-none text-body">
                    Author @Html.Raw(SortIcon("author"))
                </a>
            </th>
            <th scope="col">Video ID</th>
            <th scope="col">
                <a asp-action="Index" asp-controller="YouTubeItems" asp-route-sortBy="publicationdate" asp-route-sortDescending="@NextSortDirection("publicationdate")" asp-route-filter="@ViewBag.Filter" class="text-decoration-none text-body">
                    Publication Date @Html.Raw(SortIcon("publicationdate"))
                </a>
            </th>
            <th scope="col">
                <a asp-action="Index" asp-controller="YouTubeItems" asp-route-sortBy="addedon" asp-route-sortDescending="@NextSortDirection("addedon")" asp-route-filter="@ViewBag.Filter" class="text-decoration-none text-body">
                    Added On @Html.Raw(SortIcon("addedon"))
                </a>
            </th>
            <th scope="col" class="col-2 text-end">&nbsp;</th>
        </tr>
        </thead>
        <tbody>
        @foreach (var source in Model)
        {
            <tr>
                <td>
                    @source.Title
                    @if (!string.IsNullOrEmpty(source.Url))
                    {
                        <a href="@source.Url" title="@source.Title" target="_blank"><i class="bi bi-box-arrow-up-right"></i></a>
                    }
                </td>
                <td>@source.Author</td>
                <td>
                    @source.VideoId
                    @if (!string.IsNullOrEmpty(source.Url))
                    {
                        <a href="@source.Url" title="@source.Title" target="_blank"><i class="bi bi-box-arrow-up-right"></i></a>
                    }
                </td>
                <td><local-time value="@source.PublicationDate" /></td>
                <td><local-time value="@source.AddedOn" /></td>
                <td class="text-end">
                    <a asp-action="Details" asp-route-id="@source.Id" class="btn btn-sm btn-outline-primary" title="Details">
                        <i class="bi bi-eye"></i>
                    </a>
                    @if (User.IsInRole(RoleNames.Contributor) ||
                         User.IsInRole(RoleNames.Administrator) ||
                         User.IsInRole(RoleNames.SiteAdministrator))
                    {
                        <a asp-action="Delete" asp-route-id="@source.Id" class="btn btn-sm btn-danger" title="Delete">
                            <i class="bi bi-trash"></i>
                        </a>
                    }
                </td>
            </tr>
        }
        </tbody>
    </table>
}

<partial name="_PaginationPartial" />

@if (User.IsInRole(RoleNames.Contributor) ||
     User.IsInRole(RoleNames.Administrator) ||
     User.IsInRole(RoleNames.SiteAdministrator))
{
    <p class="mb-3">
        <a asp-action="Add" class="btn btn-primary">
            <i class="bi bi-plus-circle me-1"></i>Add New YouTube Source
        </a>
    </p>
}
