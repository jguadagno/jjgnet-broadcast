@model List<JosephGuadagno.Broadcasting.Web.Models.ScheduledItemViewModel>?

@{
    ViewData["Title"] = "Engagements Calendar";
}



<h2>Engagements Calendar</h2>
<p class="text-muted">Click an event to open the engagement page.</p>

<div id="calendar"></div>

@section Scripts {
    <environment include="Production">
        <script src="https://cdn.jsdelivr.net/npm/fullcalendar@6.1.15/index.global.min.js"
                integrity="sha256-ZztCtsADLKbUFK/X6nOYnJr0eelmV2X3dhLDB/JK6fM="
                crossorigin="anonymous"></script>
    </environment>
    <environment exclude="Production">
        <script src="~/libs/fullcalendar/index.global.min.js" asp-append-version="true"></script>
    </environment>
    <script src="~/js/schedules-calendar.js" asp-append-version="true"></script>
}

