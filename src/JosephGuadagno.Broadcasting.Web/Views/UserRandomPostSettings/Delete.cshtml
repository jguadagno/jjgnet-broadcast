@model JosephGuadagno.Broadcasting.Web.Models.UserRandomPostSettingsViewModel

@{
    ViewData["Title"] = "Delete Random Post Settings";
}

<div class="container">
    <h1 class="display-4 mb-4 text-danger">Delete Random Post Settings</h1>

    <div class="alert alert-warning" role="alert">
        <i class="bi bi-exclamation-triangle-fill me-2"></i>
        <strong>Warning:</strong> Are you sure you want to delete this random post configuration?
    </div>

    <div class="card">
        <div class="card-body">
            <dl class="row">
                <dt class="col-sm-3">Platform</dt>
                <dd class="col-sm-9"><i class="bi @Model.SocialMediaPlatformIcon me-2"></i>@Model.SocialMediaPlatformName</dd>

                <dt class="col-sm-3">Cron Expression</dt>
                <dd class="col-sm-9"><code>@Model.CronExpression</code></dd>

                <dt class="col-sm-3">Cutoff Date</dt>
                <dd class="col-sm-9">
                    @if (string.IsNullOrWhiteSpace(Model.CutoffDateUtc))
                    {
                        <span class="text-muted">—</span>
                    }
                    else
                    {
                        <local-time value="@DateTimeOffset.Parse(Model.CutoffDateUtc)" />
                    }
                </dd>

                <dt class="col-sm-3">Excluded Categories</dt>
                <dd class="col-sm-9">@(string.IsNullOrWhiteSpace(Model.ExcludedCategoriesText) ? "—" : Model.ExcludedCategoriesText)</dd>

                <dt class="col-sm-3">Active</dt>
                <dd class="col-sm-9">@(Model.IsActive ? "Yes" : "No")</dd>

                <dt class="col-sm-3">Created On</dt>
                <dd class="col-sm-9"><local-time value="@Model.CreatedOn" /></dd>
            </dl>
        </div>
    </div>

    <form asp-action="Delete" asp-controller="UserRandomPostSettings" asp-route-id="@Model.Id" method="post" class="mt-3">
        <input type="hidden" asp-for="Id" />
        <button type="submit" class="btn btn-danger" data-loading-text="Deleting...">
            <i class="bi bi-trash me-1"></i>Yes, Delete
        </button>
        <a asp-action="Index" asp-controller="UserRandomPostSettings" class="btn btn-secondary ms-2">
            <i class="bi bi-x-circle me-1"></i>Cancel
        </a>
    </form>
</div>
