@model JosephGuadagno.Broadcasting.Web.Models.TwitterPlatformSettingsViewModel

@{
    ViewData["Title"] = "Twitter / X Settings";
}

<div class="d-flex flex-column flex-lg-row justify-content-between align-items-lg-center gap-3 mb-4">
    <div>
        <h1 class="mb-1">
            <i class="bi bi-twitter-x me-2"></i>Twitter / X Settings
        </h1>
        <p class="text-muted mb-0">Your Twitter / X platform configuration.</p>
    </div>
    <div>
        <a asp-controller="Dispatchers" asp-action="Index" class="btn btn-outline-secondary">
            <i class="bi bi-arrow-left me-1"></i>All Dispatchers
        </a>
    </div>
</div>

<div class="card shadow-sm">
    <div class="card-header d-flex justify-content-between align-items-center">
        <div>
            <i class="bi bi-twitter-x me-2"></i><strong>Twitter / X</strong>
        </div>
        <span class="badge @(Model.IsEnabled ? "text-bg-success" : "text-bg-secondary")">
            @(Model.IsEnabled ? "Enabled" : "Disabled")
        </span>
    </div>
    <div class="card-body">
        @if (Model.Id == 0)
        {
            <p class="text-muted">Twitter / X has not been configured yet.</p>
        }
        else
        {
            <dl class="row mb-0">
                <dt class="col-sm-4">Consumer key</dt>
                <dd class="col-sm-8">@(Model.HasConsumerKey ? Model.MaskedValue : "Not set")</dd>
                <dt class="col-sm-4">Consumer secret</dt>
                <dd class="col-sm-8">@(Model.HasConsumerSecret ? Model.MaskedValue : "Not set")</dd>
                <dt class="col-sm-4">Access token</dt>
                <dd class="col-sm-8">@(Model.HasAccessToken ? Model.MaskedValue : "Not set")</dd>
                <dt class="col-sm-4">Access token secret</dt>
                <dd class="col-sm-8">@(Model.HasAccessTokenSecret ? Model.MaskedValue : "Not set")</dd>
            </dl>
        }
    </div>
    <div class="card-footer text-end">
        <a asp-action="Edit" class="btn btn-primary btn-sm">
            <i class="bi bi-pencil me-1"></i>@(Model.Id == 0 ? "Configure" : "Edit Settings")
        </a>
    </div>
</div>
