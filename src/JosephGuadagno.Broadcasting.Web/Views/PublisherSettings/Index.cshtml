@model JosephGuadagno.Broadcasting.Web.Models.UserPublisherSettingsPageViewModel

@{
    ViewData["Title"] = Model.IsManagedBySiteAdmin
        ? $"Publisher Settings - {Model.TargetUserDisplayName ?? Model.TargetUserEntraOid}"
        : "Publisher Settings";
}

<div class="d-flex flex-column flex-lg-row justify-content-between align-items-lg-center gap-3 mb-4">
    <div>
        <h1 class="mb-1">
            <i class="bi bi-broadcast-pin me-2"></i>Publisher Settings
        </h1>
        <p class="text-muted mb-0">
            Configure the social accounts this application can publish to on your behalf.
        </p>
    </div>
</div>

@if (Model.IsManagedBySiteAdmin)
{
    <div class="alert alert-info" role="alert">
        <i class="bi bi-shield-lock me-2"></i>
        You are managing publisher settings for <strong>@(Model.TargetUserDisplayName ?? Model.TargetUserEntraOid)</strong>.
    </div>
}

<div class="row g-4">
    @foreach (var platform in Model.Platforms)
    {
        <div class="col-12 col-xl-6">
            <div class="card h-100 @(platform.IsConfigured ? "shadow-sm" : "border-secondary-subtle")">
                <div class="card-header d-flex justify-content-between align-items-center">
                    <div>
                        <i class="bi @(string.IsNullOrWhiteSpace(platform.PlatformIcon) ? "bi-broadcast" : platform.PlatformIcon) me-2"></i>
                        <strong>@platform.DisplayName</strong>
                    </div>
                    @if (platform.IsConfigured)
                    {
                        <span class="badge @(platform.IsEnabled ? "text-bg-success" : "text-bg-secondary")">
                            @(platform.IsEnabled ? "Enabled" : "Disabled")
                        </span>
                    }
                    @if (!string.IsNullOrWhiteSpace(platform.CredentialSetupDocumentationUrl))
                    {
                        <a href="@platform.CredentialSetupDocumentationUrl" target="_blank" rel="noopener noreferrer" class="btn btn-sm btn-outline-info ms-2">
                            <i class="bi bi-book"></i> Setup guide
                        </a>
                    }
                </div>
                <partial name="@platform.PartialViewName" model="platform" />
            </div>
        </div>
    }
</div>

@section Scripts {
    @{ await Html.RenderPartialAsync("_ValidationScriptsPartial"); }
}
