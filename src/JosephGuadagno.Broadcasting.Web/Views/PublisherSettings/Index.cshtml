@model JosephGuadagno.Broadcasting.Web.Models.UserPublisherSettingsPageViewModel

@{
		ViewData["Title"] = Model.IsManagedBySiteAdmin
				? $"Publisher Settings - {Model.TargetUserDisplayName ?? Model.TargetUserEntraOid}"
				: "Publisher Settings";
}

<div class="d-flex flex-column flex-lg-row justify-content-between align-items-lg-center gap-3 mb-4">
		<div>
				<h1 class="mb-1">
						<i class="bi bi-broadcast-pin me-2"></i>Publisher Settings
				</h1>
				<p class="text-muted mb-0">
						Configure the social accounts this application can publish to on your behalf.
				</p>
		</div>
</div>

@if (Model.IsManagedBySiteAdmin)
{
		<div class="alert alert-info" role="alert">
				<i class="bi bi-shield-lock me-2"></i>
				You are managing publisher settings for
				<strong>@(Model.TargetUserDisplayName ?? Model.TargetUserEntraOid)</strong>.
		</div>
}

<div class="table-responsive">
		<table class="table table-striped table-hover table-bordered">
				<thead>
				<tr>
						<th>Platform</th>
						<th>Status</th>
						<th>Configured</th>
						<th></th>
				</tr>
				</thead>
				<tbody>
				@foreach (var platform in Model.Platforms)
				{
						<tr>
								<td>
										<i class="bi @(string.IsNullOrWhiteSpace(platform.PlatformIcon) ? "bi-broadcast" : platform.PlatformIcon) me-2"></i>
										@platform.DisplayName
								</td>
								<td>
										@if (!platform.IsConfigured)
										{
												<span class="badge text-bg-secondary">Not supported</span>
										}
										else if (platform.IsEnabled)
										{
												<span class="badge text-bg-success">Enabled</span>
										}
										else
										{
												<span class="badge text-bg-secondary">Disabled</span>
										}
								</td>
								<td>
										@if (platform.IsConfigured)
										{
												@if (platform.Id > 0)
												{
														<i class="bi bi-check-circle-fill text-success" title="Settings saved"></i>
												}
												else
												{
														<i class="bi bi-dash-circle text-muted" title="Not yet configured"></i>
												}
										}
								</td>
								<td class="text-end">
										@if (platform.IsConfigured)
										{
												<a asp-action="Edit"
												   asp-route-id="@platform.SocialMediaPlatformId"
												   asp-route-userOid="@(Model.IsManagedBySiteAdmin ? Model.TargetUserEntraOid : null)"
												   class="btn btn-sm btn-outline-primary">
														<i class="bi bi-pencil me-1"></i>Edit
												</a>
										}
								</td>
						</tr>
				}
				</tbody>
		</table>
</div>

