@model JosephGuadagno.Broadcasting.Web.Models.BlueskyPublisherSettingsViewModel

<div class="card h-100 shadow-sm">
    <div class="card-header d-flex justify-content-between align-items-center">
        <div>
            <i class="bi @(string.IsNullOrWhiteSpace(Model.PlatformIcon) ? "bi-broadcast" : Model.PlatformIcon) me-2"></i>
            <strong>@Model.PlatformName</strong>
        </div>
        <span class="badge @(Model.IsEnabled ? "text-bg-success" : "text-bg-secondary")">
            @(Model.IsEnabled ? "Enabled" : "Disabled")
        </span>
        @if (!string.IsNullOrWhiteSpace(Model.CredentialSetupDocumentationUrl))
        {
            <a href="@Model.CredentialSetupDocumentationUrl" target="_blank" rel="noopener noreferrer" class="btn btn-sm btn-outline-info ms-2">
                <i class="bi bi-book"></i> Setup guide
            </a>
        }
    </div>
    <div class="card-body">
        <form asp-action="SaveBluesky"method="post" novalidate>
            <div asp-validation-summary="ModelOnly" class="text-danger mb-3"></div>
            <input asp-for="Id" type="hidden" />
            <input asp-for="CreatedByEntraOid" type="hidden" />
            <input asp-for="SocialMediaPlatformId" type="hidden" />
            <input asp-for="PlatformName" type="hidden" />
            <input asp-for="PlatformIcon" type="hidden" />
            <input asp-for="HasAppPassword" type="hidden" />

            <div class="form-check form-switch mb-3">
                <input asp-for="IsEnabled" class="form-check-input" />
                <label asp-for="IsEnabled" class="form-check-label">Enable @Model.PlatformName publishing</label>
            </div>

            <div class="mb-3">
                <label asp-for="UserName" class="form-label"></label>
                <input asp-for="UserName" class="form-control" autocomplete="username" />
                <span asp-validation-for="UserName" class="text-danger"></span>
            </div>

            <div class="rounded border p-3 bg-body-tertiary">
                <div class="d-flex justify-content-between align-items-center mb-2">
                    <h2 class="h6 mb-0">Credentials</h2>
                    @if (Model.HasAppPassword)
                    {
                        <span class="badge text-bg-secondary">Stored</span>
                    }
                </div>
                @if (Model.HasAppPassword)
                {
                    <p class="text-muted small mb-3">
                        App password: <span class="fw-semibold">@Model.MaskedValue</span>
                    </p>
                }
                <div class="form-check mb-3">
                    <input asp-for="ChangeCredentials" class="form-check-input" />
                    <label asp-for="ChangeCredentials" class="form-check-label">Change credentials</label>
                </div>
                <div class="mb-0">
                    <label asp-for="AppPassword" class="form-label"></label>
                    <input asp-for="AppPassword" class="form-control" autocomplete="new-password" placeholder="@(Model.HasAppPassword ? "Leave blank to keep the stored app password" : "Enter app password")" />
                    <div class="form-text">Stored secrets are never shown again after save.</div>
                    <span asp-validation-for="AppPassword" class="text-danger"></span>
                </div>
            </div>

            <div class="mt-3 d-flex gap-2">
                <button type="submit" class="btn btn-primary">
                    <i class="bi bi-floppy me-2"></i>Save
                </button>
            </div>
        </form>
    </div>
</div>
