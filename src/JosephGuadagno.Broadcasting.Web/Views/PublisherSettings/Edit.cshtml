@model JosephGuadagno.Broadcasting.Web.Models.PublisherPlatformSettingsViewModel

@{
    ViewData["Title"] = Model.IsManagedBySiteAdmin
        ? $"Edit Publisher Settings - {Model.DisplayName}"
        : $"Edit {Model.DisplayName} Settings";
}

<div class="d-flex flex-column flex-lg-row justify-content-between align-items-lg-center gap-3 mb-4">
    <div>
        <h1 class="mb-1">
            <i class="bi @(string.IsNullOrWhiteSpace(Model.PlatformIcon) ? "bi-broadcast" : Model.PlatformIcon) me-2"></i>@Model.DisplayName Settings
        </h1>
        <p class="text-muted mb-0">
            Configure the settings for publishing to @Model.DisplayName.
        </p>
    </div>
    <div>
        <a asp-action="Index"
           asp-route-userOid="@(Model.IsManagedBySiteAdmin ? Model.CreatedByEntraOid : null)"
           class="btn btn-outline-secondary">
            <i class="bi bi-arrow-left me-1"></i>Publisher Settings
        </a>
    </div>
</div>

@if (Model.IsManagedBySiteAdmin)
{
    <div class="alert alert-info" role="alert">
        <i class="bi bi-shield-lock me-2"></i>
        You are managing publisher settings for <strong>@Model.CreatedByEntraOid</strong>.
    </div>
}

<div class="card shadow-sm">
    <div class="card-header d-flex justify-content-between align-items-center">
        <div>
            <i class="bi @(string.IsNullOrWhiteSpace(Model.PlatformIcon) ? "bi-broadcast" : Model.PlatformIcon) me-2"></i>
            <strong>@Model.DisplayName</strong>
        </div>
        @if (Model.IsConfigured)
        {
            <span class="badge @(Model.IsEnabled ? "text-bg-success" : "text-bg-secondary")">
                @(Model.IsEnabled ? "Enabled" : "Disabled")
            </span>
        }
        @if (!string.IsNullOrWhiteSpace(Model.CredentialSetupDocumentationUrl))
        {
            <a href="@Model.CredentialSetupDocumentationUrl" target="_blank" rel="noopener noreferrer" class="btn btn-sm btn-outline-info ms-2">
                <i class="bi bi-book"></i> Setup guide
            </a>
        }
    </div>
    <partial name="@Model.PartialViewName" model="Model" />
</div>

@section Scripts {
    @{ await Html.RenderPartialAsync("_ValidationScriptsPartial"); }
}
