@model JosephGuadagno.Broadcasting.Web.Models.FacebookPlatformSettingsViewModel

@{
    ViewData["Title"] = "Facebook Settings";
}

<div class="d-flex flex-column flex-lg-row justify-content-between align-items-lg-center gap-3 mb-4">
    <div>
        <h1 class="mb-1">
            <i class="bi bi-facebook me-2"></i>Facebook Settings
        </h1>
        <p class="text-muted mb-0">Your Facebook platform configuration.</p>
    </div>
    <div>
        <a asp-controller="Platforms" asp-action="Index" class="btn btn-outline-secondary">
            <i class="bi bi-arrow-left me-1"></i>All Platforms
        </a>
    </div>
</div>

<div class="card shadow-sm">
    <div class="card-header d-flex justify-content-between align-items-center">
        <div>
            <i class="bi bi-facebook me-2"></i><strong>Facebook</strong>
        </div>
        <span class="badge @(Model.IsEnabled ? "text-bg-success" : "text-bg-secondary")">
            @(Model.IsEnabled ? "Enabled" : "Disabled")
        </span>
    </div>
    <div class="card-body">
        @if (Model.Id == 0)
        {
            <p class="text-muted">Facebook has not been configured yet.</p>
        }
        else
        {
            <dl class="row mb-0">
                <dt class="col-sm-4">Page ID</dt>
                <dd class="col-sm-8">@(Model.PageId ?? "—")</dd>
                <dt class="col-sm-4">App ID</dt>
                <dd class="col-sm-8">@(Model.AppId ?? "—")</dd>
                <dt class="col-sm-4">Page access token</dt>
                <dd class="col-sm-8">@(Model.HasPageAccessToken ? Model.MaskedValue : "Not set")</dd>
                <dt class="col-sm-4">App secret</dt>
                <dd class="col-sm-8">@(Model.HasAppSecret ? Model.MaskedValue : "Not set")</dd>
                <dt class="col-sm-4">Client token</dt>
                <dd class="col-sm-8">@(Model.HasClientToken ? Model.MaskedValue : "Not set")</dd>
            </dl>
        }
    </div>
    <div class="card-footer text-end">
        <a asp-action="Edit" class="btn btn-primary btn-sm">
            <i class="bi bi-pencil me-1"></i>@(Model.Id == 0 ? "Configure" : "Edit Settings")
        </a>
    </div>
</div>
