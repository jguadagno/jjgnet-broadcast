@model List<JosephGuadagno.Broadcasting.Web.Models.YouTubeSourceViewModel>
@{
    ViewData["Title"] = "YouTube Sources";
}
<div class="text-center">
    <h1 class="display-4">YouTube Sources</h1>
    
    @if (User.IsInRole(JosephGuadagno.Broadcasting.Domain.Constants.RoleNames.Contributor) || 
         User.IsInRole(JosephGuadagno.Broadcasting.Domain.Constants.RoleNames.Administrator) || 
         User.IsInRole(JosephGuadagno.Broadcasting.Domain.Constants.RoleNames.SiteAdministrator))
    {
        <p class="mb-3">
            <a asp-action="Add" class="btn btn-primary">
                <i class="bi bi-plus-circle me-1"></i>Add New YouTube Source
            </a>
        </p>
    }
    
    @if (TempData["SuccessMessage"] != null)
    {
        <div class="alert alert-success alert-dismissible fade show" role="alert">
            @TempData["SuccessMessage"]
            <button type="button" class="btn-close" data-bs-dismiss="alert" aria-label="Close"></button>
        </div>
    }
    @if (TempData["ErrorMessage"] != null)
    {
        <div class="alert alert-danger alert-dismissible fade show" role="alert">
            @TempData["ErrorMessage"]
            <button type="button" class="btn-close" data-bs-dismiss="alert" aria-label="Close"></button>
        </div>
    }
    
    @if (Model.Count == 0)
    {
        <p class="text-muted">No YouTube sources found.</p>
    }
    else
    {
        <table class="table table-striped">
            <thead class="thead-dark">
            <tr>
                <th scope="col">Title</th>
                <th scope="col">Author</th>
                <th scope="col">Video ID</th>
                <th scope="col">Publication Date</th>
                <th scope="col">Added On</th>
                <th scope="col" class="col-2">&nbsp;</th>
            </tr>
            </thead>
            <tbody>
            @foreach (var source in Model)
            {
                <tr>
                    <td>@source.Title</td>
                    <td>@source.Author</td>
                    <td>@source.VideoId</td>
                    <td>@source.PublicationDate.ToString("g")</td>
                    <td>@source.AddedOn.ToString("g")</td>
                    <td class="text-end">
                        <a asp-action="Details" asp-route-id="@source.Id" class="btn btn-sm btn-info" title="Details">
                            <i class="bi bi-eye"></i>
                        </a>
                        @if (User.IsInRole(JosephGuadagno.Broadcasting.Domain.Constants.RoleNames.Contributor) || 
                             User.IsInRole(JosephGuadagno.Broadcasting.Domain.Constants.RoleNames.Administrator) || 
                             User.IsInRole(JosephGuadagno.Broadcasting.Domain.Constants.RoleNames.SiteAdministrator))
                        {
                            <a asp-action="Delete" asp-route-id="@source.Id" class="btn btn-sm btn-danger" title="Delete">
                                <i class="bi bi-trash"></i>
                            </a>
                        }
                    </td>
                </tr>
            }
            </tbody>
        </table>
    }
</div>
