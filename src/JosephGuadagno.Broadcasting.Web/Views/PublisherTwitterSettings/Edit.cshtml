@model JosephGuadagno.Broadcasting.Web.Models.TwitterPublisherSettingsViewModel

@{
    ViewData["Title"] = "Edit Twitter / X Settings";
}

<div class="d-flex flex-column flex-lg-row justify-content-between align-items-lg-center gap-3 mb-4">
    <div>
        <h1 class="mb-1">
            <i class="bi bi-twitter-x me-2"></i>Twitter / X Settings
        </h1>
        <p class="text-muted mb-0">Configure the settings for publishing to Twitter / X.</p>
    </div>
    <div>
        <a asp-action="Index" class="btn btn-outline-secondary">
            <i class="bi bi-arrow-left me-1"></i>Back
        </a>
    </div>
</div>

<div class="card shadow-sm">
    <div class="card-body">
        <form asp-action="Save" method="post" novalidate>
            <div asp-validation-summary="ModelOnly" class="text-danger mb-3"></div>
            <input asp-for="Id" type="hidden" />
            <input asp-for="HasConsumerKey" type="hidden" />
            <input asp-for="HasConsumerSecret" type="hidden" />
            <input asp-for="HasAccessToken" type="hidden" />
            <input asp-for="HasAccessTokenSecret" type="hidden" />

            <div class="form-check form-switch mb-3">
                <input asp-for="IsEnabled" class="form-check-input" />
                <label asp-for="IsEnabled" class="form-check-label">Enable Twitter / X publishing</label>
            </div>

            <div class="rounded border p-3 bg-body-tertiary">
                <div class="d-flex justify-content-between align-items-center mb-2">
                    <h2 class="h6 mb-0">Credentials</h2>
                    @if (Model.HasConsumerKey || Model.HasConsumerSecret || Model.HasAccessToken || Model.HasAccessTokenSecret)
                    {
                        <span class="badge text-bg-secondary">Stored</span>
                    }
                </div>
                <ul class="small text-muted mb-3 ps-3">
                    <li>Consumer key: @(Model.HasConsumerKey ? Model.MaskedValue : "Not set")</li>
                    <li>Consumer secret: @(Model.HasConsumerSecret ? Model.MaskedValue : "Not set")</li>
                    <li>Access token: @(Model.HasAccessToken ? Model.MaskedValue : "Not set")</li>
                    <li>Access token secret: @(Model.HasAccessTokenSecret ? Model.MaskedValue : "Not set")</li>
                </ul>
                <div class="form-check form-switch mb-3">
                    <input asp-for="ChangeCredentials" class="form-check-input" />
                    <label asp-for="ChangeCredentials" class="form-check-label">Change credentials</label>
                </div>
                <div class="row g-3">
                    <div class="col-12">
                        <label asp-for="ConsumerKey" class="form-label"></label>
                        <input asp-for="ConsumerKey" class="form-control" autocomplete="new-password"
                               placeholder="Leave blank to keep the stored consumer key" />
                        <span asp-validation-for="ConsumerKey" class="text-danger"></span>
                    </div>
                    <div class="col-12">
                        <label asp-for="ConsumerSecret" class="form-label"></label>
                        <input asp-for="ConsumerSecret" class="form-control" autocomplete="new-password"
                               placeholder="Leave blank to keep the stored consumer secret" />
                        <span asp-validation-for="ConsumerSecret" class="text-danger"></span>
                    </div>
                    <div class="col-12">
                        <label asp-for="AccessToken" class="form-label"></label>
                        <input asp-for="AccessToken" class="form-control" autocomplete="new-password"
                               placeholder="Leave blank to keep the stored access token" />
                        <span asp-validation-for="AccessToken" class="text-danger"></span>
                    </div>
                    <div class="col-12">
                        <label asp-for="AccessTokenSecret" class="form-label"></label>
                        <input asp-for="AccessTokenSecret" class="form-control" autocomplete="new-password"
                               placeholder="Leave blank to keep the stored access token secret" />
                        <span asp-validation-for="AccessTokenSecret" class="text-danger"></span>
                    </div>
                </div>
            </div>

            <div class="mt-3 d-flex gap-2">
                <button type="submit" class="btn btn-primary">
                    <i class="bi bi-floppy me-2"></i>Save
                </button>
                <a asp-action="Index" class="btn btn-outline-secondary">Cancel</a>
            </div>
        </form>
    </div>
</div>

@section Scripts {
    @{ await Html.RenderPartialAsync("_ValidationScriptsPartial"); }
}
