@{
    ViewData["Title"] = "Registration Rejected";
}

<div class="container mt-5">
    <div class="row justify-content-center">
        <div class="col-md-8">
            <div class="card">
                <div class="card-header bg-danger text-white">
                    <h2 class="mb-0">
                        <i class="bi bi-x-circle me-2"></i>Registration Rejected
                    </h2>
                </div>
                <div class="card-body">
                    <div class="alert alert-danger" role="alert">
                        <h4 class="alert-heading">
                            <i class="bi bi-exclamation-triangle me-2"></i>Your Account Registration Has Been Rejected
                        </h4>
                        <p>
                            Unfortunately, your account registration has been rejected by an administrator.
                        </p>
                        
                        @if (ViewBag.ApprovalNotes != null)
                        {
                            <hr>
                            <p class="mb-0">
                                <strong>Reason:</strong><br/>
                                @ViewBag.ApprovalNotes
                            </p>
                        }
                    </div>
                    
                    <div class="alert alert-info mt-3" role="alert">
                        <p class="mb-0">
                            If you believe this is an error or would like to discuss this decision, 
                            please contact the system administrator.
                        </p>
                    </div>
                    
                    <div class="d-grid gap-2 mt-3">
                        <a asp-controller="Home" asp-action="Index" class="btn btn-primary">
                            <i class="bi bi-house-door me-2"></i>Return to Home
                        </a>
                    </div>
                </div>
            </div>
        </div>
    </div>
</div>
